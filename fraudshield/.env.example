MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=northmaple_bank_demo
NEXT_PUBLIC_FRAUD_API_USE_LOCAL_ENDPOINTS=true

# Optional AI co-assessment (OpenAI-compatible endpoint on Hugging Face)
FRAUD_AI_ENABLED=false
FRAUD_AI_BASE_URL=https://qyt7893blb71b5d3.us-east-2.aws.endpoints.huggingface.cloud/v1
FRAUD_AI_MODEL=openai/gpt-oss-120b
# Prefer FRAUD_AI_API_KEY; falls back to OPENAI_API_KEY if not set.
FRAUD_AI_API_KEY=
FRAUD_AI_TIMEOUT_MS=5000
FRAUD_AI_MAX_SESSIONS_PER_REQUEST=12
FRAUD_AI_MAX_CONCURRENCY=2
FRAUD_AI_MAX_RETRIES=2
FRAUD_AI_RETRY_BASE_DELAY_MS=700
FRAUD_AI_MAX_OUTPUT_TOKENS=512
FRAUD_AI_CACHE_TTL_MS=300000
